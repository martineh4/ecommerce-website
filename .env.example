# -------------------------------------------------------
# Database (PostgreSQL) — REQUIRED
# -------------------------------------------------------
DATABASE_URL="postgresql://user:password@host:5432/ecommerce"

# Only needed when using a connection pooler (Neon pgBouncer, Supabase, etc.)
# Uncomment directUrl in prisma/schema.prisma if you set this.
# DIRECT_URL="postgresql://user:password@host:5432/ecommerce"

# -------------------------------------------------------
# NextAuth.js — REQUIRED
# -------------------------------------------------------
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"

# Set to your production URL on Vercel (e.g. https://ecommerce-website.vercel.app)
NEXTAUTH_URL="http://localhost:3000"
