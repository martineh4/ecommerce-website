# -------------------------------------------------------
# Database (PostgreSQL)
# Use a pooled connection URL for DATABASE_URL when hosted
# on a serverless provider (Neon, Supabase, etc.)
# -------------------------------------------------------
DATABASE_URL="postgresql://user:password@localhost:5432/ecommerce"

# Required when using a connection pooler (e.g. Neon, PgBouncer).
# Set to the same value as DATABASE_URL if not using a pooler.
DIRECT_URL="postgresql://user:password@localhost:5432/ecommerce"

# -------------------------------------------------------
# NextAuth.js
# -------------------------------------------------------
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"

# Set to your production domain on Vercel:
# e.g. https://ecommerce-website.vercel.app
NEXTAUTH_URL="http://localhost:3000"
